rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── New multi-collection structure ──────────────────────────────────────
    match /collections/{collectionId} {
      // Anyone can read a publicly shared collection;
      // only the owner can read private ones.
      allow read: if resource.data.shareEnabled == true
                  || (request.auth != null
                      && request.auth.uid == resource.data.ownerId);

      // Only authenticated users can create, and only as themselves.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Only the owner can update or delete.
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }

    // ── Legacy single-collection data (kept for migration reads) ────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}