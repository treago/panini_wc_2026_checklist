rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Catalogs (card-set definitions) ────────────────────────────────────
    // Readable by everyone (shared collections need them without auth).
    // Written only via the Admin SDK — no client writes allowed.
    match /catalogs/{catalogId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Collections (per-user checklists) ──────────────────────────────────
    match /collections/{collectionId} {
      // Public share link OR authenticated owner.
      allow read: if resource.data.shareEnabled == true
                  || (request.auth != null
                      && request.auth.uid == resource.data.ownerId);

      // Authenticated users may create their own collections only.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Only the owner may update or delete.
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }

    // ── Legacy user documents (kept so old migration reads still work) ──────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}