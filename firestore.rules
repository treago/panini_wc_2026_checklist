rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User documents & all subcollections ────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Checklist subcollection — owns all sticker documents
      match /checklist/{stickerId} {
        allow read: if request.auth != null
                    && request.auth.uid == userId;

        allow write: if request.auth != null
                     && request.auth.uid == userId
                     // qty must be a whole number between 0 and 99
                     && request.resource.data.qty is int
                     && request.resource.data.qty >= 0
                     && request.resource.data.qty <= 99
                     // only allow known fields on a sticker document
                     && request.resource.data.keys().hasOnly([
                          'qty', 'updatedAt'
                        ]);
      }

      // Any other subcollections under /users/{userId} — owner only
      match /{subcollection=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ─── Share links ─────────────────────────────────────────────────────────
    // Anyone can read a share doc (needed to resolve the owner).
    // Only the owner can create or delete their own share link.
    match /shares/{shareId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId
                    // only allow known fields on a share document
                    && request.resource.data.keys().hasOnly([
                         'ownerId', 'createdAt'
                       ])
                    && request.resource.data.createdAt is int;

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      // No updates — shares are create-or-delete only
      allow update: if false;
    }

  }
}
